{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "odoo-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "McpAgent",
        "class_name": "McpAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["McpAgent"]
    }
  ]
}
