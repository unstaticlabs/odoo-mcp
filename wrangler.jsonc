{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "odoo-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    // Persist console.log in Workers Logs — carries the write_context audit lines
    // (agent-declared intent on write tools) and general request telemetry.
    "enabled": true
  },
  "vars": {
    // Dev default for the safe-write confirmation-token HMAC. Override with a real
    // secret in production via `wrangler secret put CONFIRMATION_SECRET`.
    // "CONFIRMATION_SECRET": "dev-confirmation-secret-do-not-use-in-prod" <-- not a line here because this is a secret. otherwise when creating the secret, wrangler will complain that this is declared as a plaintext var.
  },
  "kv_namespaces": [
    {
      // Token/grant/client storage for the ChatGPT OAuth shim
      // (@cloudflare/workers-oauth-provider). Odoo credentials inside grants
      // are end-to-end encrypted; see docs/product/auth.md.
      "binding": "OAUTH_KV",
      "id": "87163e0f22e54140b5e87ed656844cc7"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "McpAgent",
        "class_name": "McpAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["McpAgent"]
    }
  ]
}
